{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "alertName": {
      "type": "string",
      "defaultValue": "AVS-ServiceHealth-Alert",
      "metadata": {
        "description": "Base name for the Service Health alert rules."
      }
    },
    "actionGroupId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the action group to notify when Service Health events occur.",
        "strongType": "Microsoft.Insights/actionGroups"
      }
    },
    "monitorServiceIssues": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Alert on service issues (outages, degradations)."
      }
    },
    "monitorPlannedMaintenance": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Alert on planned maintenance (ESXi, vCenter, NSX upgrades)."
      }
    },
    "monitorHealthAdvisories": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Alert on health advisories (action recommended)."
      }
    },
    "monitorSecurityAdvisories": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Alert on security advisories (VMSAs, CVEs)."
      }
    }
  },
  "variables": {
    "alertScope": "[format('/subscriptions/{0}', subscription().subscriptionId)]"
  },
  "resources": [
    {
      "condition": "[parameters('monitorServiceIssues')]",
      "type": "Microsoft.Insights/activityLogAlerts",
      "apiVersion": "2020-10-01",
      "name": "[format('{0}-ServiceIssues', parameters('alertName'))]",
      "location": "Global",
      "properties": {
        "scopes": [
          "[variables('alertScope')]"
        ],
        "condition": {
          "allOf": [
            {
              "field": "category",
              "equals": "ServiceHealth"
            },
            {
              "field": "properties.incidentType",
              "equals": "Incident"
            },
            {
              "field": "properties.impactedServices[*].ServiceName",
              "containsAny": [
                "Azure VMware Solution"
              ]
            }
          ]
        },
        "actions": {
          "actionGroups": [
            {
              "actionGroupId": "[parameters('actionGroupId')]"
            }
          ]
        },
        "enabled": true,
        "description": "Alerts when Azure VMware Solution experiences a service issue (outage or degradation)."
      }
    },
    {
      "condition": "[parameters('monitorPlannedMaintenance')]",
      "type": "Microsoft.Insights/activityLogAlerts",
      "apiVersion": "2020-10-01",
      "name": "[format('{0}-PlannedMaintenance', parameters('alertName'))]",
      "location": "Global",
      "properties": {
        "scopes": [
          "[variables('alertScope')]"
        ],
        "condition": {
          "allOf": [
            {
              "field": "category",
              "equals": "ServiceHealth"
            },
            {
              "field": "properties.incidentType",
              "equals": "Maintenance"
            },
            {
              "field": "properties.impactedServices[*].ServiceName",
              "containsAny": [
                "Azure VMware Solution"
              ]
            }
          ]
        },
        "actions": {
          "actionGroups": [
            {
              "actionGroupId": "[parameters('actionGroupId')]"
            }
          ]
        },
        "enabled": true,
        "description": "Alerts when Azure VMware Solution has planned maintenance (ESXi, vCenter, NSX upgrades)."
      }
    },
    {
      "condition": "[parameters('monitorHealthAdvisories')]",
      "type": "Microsoft.Insights/activityLogAlerts",
      "apiVersion": "2020-10-01",
      "name": "[format('{0}-HealthAdvisory', parameters('alertName'))]",
      "location": "Global",
      "properties": {
        "scopes": [
          "[variables('alertScope')]"
        ],
        "condition": {
          "allOf": [
            {
              "field": "category",
              "equals": "ServiceHealth"
            },
            {
              "field": "properties.incidentType",
              "equals": "ActionRequired"
            },
            {
              "field": "properties.impactedServices[*].ServiceName",
              "containsAny": [
                "Azure VMware Solution"
              ]
            }
          ]
        },
        "actions": {
          "actionGroups": [
            {
              "actionGroupId": "[parameters('actionGroupId')]"
            }
          ]
        },
        "enabled": true,
        "description": "Alerts when Azure VMware Solution has health advisories (action recommended)."
      }
    },
    {
      "condition": "[parameters('monitorSecurityAdvisories')]",
      "type": "Microsoft.Insights/activityLogAlerts",
      "apiVersion": "2020-10-01",
      "name": "[format('{0}-SecurityAdvisory', parameters('alertName'))]",
      "location": "Global",
      "properties": {
        "scopes": [
          "[variables('alertScope')]"
        ],
        "condition": {
          "allOf": [
            {
              "field": "category",
              "equals": "ServiceHealth"
            },
            {
              "field": "properties.incidentType",
              "equals": "Security"
            },
            {
              "field": "properties.impactedServices[*].ServiceName",
              "containsAny": [
                "Azure VMware Solution"
              ]
            }
          ]
        },
        "actions": {
          "actionGroups": [
            {
              "actionGroupId": "[parameters('actionGroupId')]"
            }
          ]
        },
        "enabled": true,
        "description": "Alerts when Azure VMware Solution has security advisories (VMSAs, CVEs)."
      }
    }
  ]
}
