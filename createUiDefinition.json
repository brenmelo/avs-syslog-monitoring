{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy AVS Syslog alert rules to monitor your Azure VMware Solution private cloud. This wizard lets you pick which alerts to enable and configure notification action groups.",
        "location": {
          "visible": true
        },
        "subscription": {
          "resourceProviders": ["Microsoft.Insights"]
        },
        "resourceGroup": {
          "allowExisting": true
        }
      }
    },
    "basics": [
      {
        "name": "workspaceSelector",
        "type": "Microsoft.Solutions.ResourceSelector",
        "label": "Log Analytics Workspace",
        "toolTip": "The workspace that receives AVSSyslog data from your AVS private cloud diagnostic setting.",
        "resourceType": "Microsoft.OperationalInsights/workspaces",
        "options": {
          "filter": {
            "subscription": "onBasics",
            "location": "all"
          }
        }
      },
      {
        "name": "alertNamePrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Alert Name Prefix",
        "defaultValue": "AVS",
        "toolTip": "Prefix added to every alert rule name, e.g. AVS-Syslog-Sev0-Emergency.",
        "constraints": {
          "required": true,
          "regex": "^[a-zA-Z0-9-]{1,20}$",
          "validationMessage": "Only letters, numbers, and hyphens. Max 20 characters."
        }
      }
    ],
    "steps": [
      {
        "name": "notifications",
        "label": "Action Groups",
        "elements": [
          {
            "name": "infoBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Info",
              "text": "Select the action groups to notify when alerts fire. You can use one group for all severities or separate groups per tier. Leave a dropdown empty to disable notifications for that tier — alerts will still fire and be visible in Azure Monitor, just without paging anyone.",
              "style": "Info"
            }
          },
          {
            "name": "createNewBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "None",
              "text": "Don't have an action group yet? Create one in the Azure portal first, then return to this wizard.",
              "uri": "https://portal.azure.com/#blade/HubsExtension/BrowseResource/resourceType/Microsoft.Insights%2FactionGroups",
              "style": "Upsell"
            }
          },
          {
            "name": "strategyBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "None",
              "text": "Need help choosing a notification strategy? See the action group strategy guide (Email, SMS, Teams, Webhook, ITSM, Logic App, etc.) in the README.",
              "uri": "https://github.com/brenmelo/avs-syslog-monitoring#-action-group-routing",
              "style": "Info"
            }
          },
          {
            "name": "useSameForAll",
            "type": "Microsoft.Common.CheckBox",
            "label": "Use the same action group for all severities (simple setup)",
            "defaultValue": false,
            "toolTip": "If checked, the Severity 0 selection below will be reused for Sev 1 and Sev 2, and the other dropdowns will be hidden."
          },
          {
            "name": "actionGroupSev0",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "🔴 Action Group — Severity 0 (Emergency, Alert, Host-down, Heartbeat)",
            "toolTip": "Notified for the most critical alerts. Leave empty to skip.",
            "resourceType": "Microsoft.Insights/actionGroups",
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "all"
              }
            }
          },
          {
            "name": "actionGroupSev1",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "🟠 Action Group — Severity 1 (Critical, VM, DNS, Role changes)",
            "toolTip": "Notified for high-priority alerts. Leave empty to skip.",
            "resourceType": "Microsoft.Insights/actionGroups",
            "visible": "[not(steps('notifications').useSameForAll)]",
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "all"
              }
            }
          },
          {
            "name": "actionGroupSev2",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "🟡 Action Group — Severity 2 (Error, DFW, Maintenance, Guest Reboot)",
            "toolTip": "Notified for moderate-priority alerts. Leave empty to skip.",
            "resourceType": "Microsoft.Insights/actionGroups",
            "visible": "[not(steps('notifications').useSameForAll)]",
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "all"
              }
            }
          },
          {
            "name": "noGroupWarning",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[and(empty(steps('notifications').actionGroupSev0.id), empty(steps('notifications').actionGroupSev1.id), empty(steps('notifications').actionGroupSev2.id))]",
            "options": {
              "icon": "Warning",
              "text": "⚠️ No action groups selected. Alert rules will still be deployed and visible in Azure Monitor, but nobody will be notified when they fire. Select at least one action group above for notifications to be sent.",
              "style": "Warning"
            }
          }
        ]
      },
      {
        "name": "alertSelection",
        "label": "Select Alerts",
        "elements": [
          {
            "name": "severitySection",
            "type": "Microsoft.Common.Section",
            "label": "Part 1 — Severity-Based Alerts",
            "elements": [
              {
                "name": "deploySev0Emergency",
                "type": "Microsoft.Common.CheckBox",
                "label": "Sev 0 — Emergency (emerg / emergency)",
                "defaultValue": true
              },
              {
                "name": "deploySev0Alert",
                "type": "Microsoft.Common.CheckBox",
                "label": "Sev 0 — Alert",
                "defaultValue": true
              },
              {
                "name": "deploySev1Critical",
                "type": "Microsoft.Common.CheckBox",
                "label": "Sev 1 — Critical (crit / critical)",
                "defaultValue": true
              },
              {
                "name": "deploySev2Error",
                "type": "Microsoft.Common.CheckBox",
                "label": "Sev 2 — Error (err / error) — optional, can be noisy",
                "defaultValue": false
              }
            ]
          },
          {
            "name": "eventSection",
            "type": "Microsoft.Common.Section",
            "label": "Part 2 — Event-Specific Alerts",
            "elements": [
              {
                "name": "eventInfoBox",
                "type": "Microsoft.Common.InfoBox",
                "options": {
                  "text": "Each event alert is routed to the action group matching its Azure severity: Sev 0 = Emergency-tier, Sev 1 = High-tier, Sev 2 = Moderate-tier (as configured in the Action Groups step).",
                  "style": "Info"
                }
              },
              {
                "name": "deployHostConnectionLost",
                "type": "Microsoft.Common.CheckBox",
                "label": "Host Connection Lost → Sev 0",
                "defaultValue": true
              },
              {
                "name": "deployHostShutdown",
                "type": "Microsoft.Common.CheckBox",
                "label": "Host Shutdown → Sev 0",
                "defaultValue": true
              },
              {
                "name": "deployVmDisconnected",
                "type": "Microsoft.Common.CheckBox",
                "label": "VM Disconnected → Sev 1",
                "defaultValue": true
              },
              {
                "name": "deployVmRemovedFromInventory",
                "type": "Microsoft.Common.CheckBox",
                "label": "VM Removed from Inventory → Sev 1",
                "defaultValue": true
              },
              {
                "name": "deployVmGuestReboot",
                "type": "Microsoft.Common.CheckBox",
                "label": "VM Guest Reboot → Sev 2",
                "defaultValue": true
              },
              {
                "name": "deployDnsFailures",
                "type": "Microsoft.Common.CheckBox",
                "label": "DNS Failures (threshold-based) → Sev 1",
                "defaultValue": true
              },
              {
                "name": "deployDfwSpike",
                "type": "Microsoft.Common.CheckBox",
                "label": "Distributed Firewall Blocked Spike (threshold-based) → Sev 2",
                "defaultValue": true
              },
              {
                "name": "deployHostMaintenanceMode",
                "type": "Microsoft.Common.CheckBox",
                "label": "Host Maintenance Mode → Sev 2",
                "defaultValue": true
              },
              {
                "name": "deployRolePermissionChanges",
                "type": "Microsoft.Common.CheckBox",
                "label": "Role / Permission Changes (Security Audit) → Sev 1",
                "defaultValue": true
              },
              {
                "name": "deploySyslogIngestionHeartbeat",
                "type": "Microsoft.Common.CheckBox",
                "label": "Syslog Ingestion Heartbeat (no-data alert) → Sev 0",
                "defaultValue": true
              }
            ]
          }
        ]
      },
      {
        "name": "thresholds",
        "label": "Thresholds",
        "elements": [
          {
            "name": "infoBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "text": "Set alert thresholds for volume-based alerts. These thresholds apply per host per 15-minute evaluation window.",
              "style": "Info"
            }
          },
          {
            "name": "errThresholdPer15m",
            "type": "Microsoft.Common.Slider",
            "label": "Error events threshold (per 15 min)",
            "subLabel": "events",
            "defaultValue": 5,
            "min": 1,
            "max": 100,
            "showStepMarkers": false,
            "toolTip": "Number of err/error events per HostName + AppName in 15 minutes before alerting."
          },
          {
            "name": "dnsFailureThresholdPer15m",
            "type": "Microsoft.Common.Slider",
            "label": "DNS failure threshold (per 15 min)",
            "subLabel": "failures",
            "defaultValue": 10,
            "min": 1,
            "max": 200,
            "showStepMarkers": false,
            "toolTip": "Number of DNS failures per host in 15 minutes before alerting."
          },
          {
            "name": "dfwSpikeThresholdPer15m",
            "type": "Microsoft.Common.Slider",
            "label": "DFW blocked spike threshold (per 15 min)",
            "subLabel": "blocks",
            "defaultValue": 50,
            "min": 1,
            "max": 500,
            "showStepMarkers": false,
            "toolTip": "Number of blocked firewall events per host in 15 minutes before alerting."
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "workspaceResourceId": "[basics('workspaceSelector').id]",
      "alertNamePrefix": "[basics('alertNamePrefix')]",
      "actionGroupIdSev0": "[if(empty(steps('notifications').actionGroupSev0.id), '', steps('notifications').actionGroupSev0.id)]",
      "actionGroupIdSev1": "[if(steps('notifications').useSameForAll, if(empty(steps('notifications').actionGroupSev0.id), '', steps('notifications').actionGroupSev0.id), if(empty(steps('notifications').actionGroupSev1.id), '', steps('notifications').actionGroupSev1.id))]",
      "actionGroupIdSev2": "[if(steps('notifications').useSameForAll, if(empty(steps('notifications').actionGroupSev0.id), '', steps('notifications').actionGroupSev0.id), if(empty(steps('notifications').actionGroupSev2.id), '', steps('notifications').actionGroupSev2.id))]",
      "errThresholdPer15m": "[steps('thresholds').errThresholdPer15m]",
      "dnsFailureThresholdPer15m": "[steps('thresholds').dnsFailureThresholdPer15m]",
      "dfwSpikeThresholdPer15m": "[steps('thresholds').dfwSpikeThresholdPer15m]",
      "deploySev0Emergency": "[steps('alertSelection').severitySection.deploySev0Emergency]",
      "deploySev0Alert": "[steps('alertSelection').severitySection.deploySev0Alert]",
      "deploySev1Critical": "[steps('alertSelection').severitySection.deploySev1Critical]",
      "deploySev2Error": "[steps('alertSelection').severitySection.deploySev2Error]",
      "deployHostConnectionLost": "[steps('alertSelection').eventSection.deployHostConnectionLost]",
      "deployHostShutdown": "[steps('alertSelection').eventSection.deployHostShutdown]",
      "deployVmDisconnected": "[steps('alertSelection').eventSection.deployVmDisconnected]",
      "deployVmRemovedFromInventory": "[steps('alertSelection').eventSection.deployVmRemovedFromInventory]",
      "deployVmGuestReboot": "[steps('alertSelection').eventSection.deployVmGuestReboot]",
      "deployDnsFailures": "[steps('alertSelection').eventSection.deployDnsFailures]",
      "deployDfwSpike": "[steps('alertSelection').eventSection.deployDfwSpike]",
      "deployHostMaintenanceMode": "[steps('alertSelection').eventSection.deployHostMaintenanceMode]",
      "deployRolePermissionChanges": "[steps('alertSelection').eventSection.deployRolePermissionChanges]",
      "deploySyslogIngestionHeartbeat": "[steps('alertSelection').eventSection.deploySyslogIngestionHeartbeat]"
    }
  }
}
