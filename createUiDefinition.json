{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy AVS Syslog alert rules to monitor your Azure VMware Solution private cloud. This wizard lets you pick which alerts to enable and configure notification action groups.",
        "location": {
          "visible": true
        },
        "subscription": {
          "resourceProviders": ["Microsoft.Insights"]
        },
        "resourceGroup": {
          "allowExisting": true
        }
      }
    },
    "basics": [
      {
        "name": "workspaceSelector",
        "type": "Microsoft.Solutions.ResourceSelector",
        "label": "Log Analytics Workspace",
        "toolTip": "The workspace that receives AVSSyslog data from your AVS private cloud diagnostic setting.",
        "resourceType": "Microsoft.OperationalInsights/workspaces",
        "options": {
          "filter": {
            "subscription": "onBasics",
            "location": "all"
          }
        }
      },
      {
        "name": "alertNamePrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Alert Name Prefix",
        "defaultValue": "AVS",
        "toolTip": "Prefix added to every alert rule name, e.g. AVS-Syslog-Sev0-Emergency.",
        "constraints": {
          "required": true,
          "regex": "^[a-zA-Z0-9-]{1,20}$",
          "validationMessage": "Only letters, numbers, and hyphens. Max 20 characters."
        }
      }
    ],
    "steps": [
      {
        "name": "notifications",
        "label": "Action Groups",
        "elements": [
          {
            "name": "infoBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Info",
              "text": "Select the action groups to notify when alerts fire. You can use one group for all severities or separate groups per tier. Leave a dropdown empty to disable notifications for that tier — alerts will still fire and be visible in Azure Monitor, just without paging anyone.",
              "style": "Info"
            }
          },
          {
            "name": "createNewBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "None",
              "text": "Don't have an action group yet? Follow the official guide to create one (opens in a new tab), then come back to this wizard and refresh the dropdowns.",
              "uri": "https://learn.microsoft.com/azure/azure-monitor/alerts/action-groups#create-an-action-group-in-the-azure-portal",
              "style": "Upsell"
            }
          },
          {
            "name": "strategyBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "None",
              "text": "Need help choosing a notification strategy? See the action group strategy guide (Email, SMS, Teams, Webhook, ITSM, Logic App, etc.) in the README.",
              "uri": "https://github.com/brenmelo/avs-syslog-monitoring#-action-group-routing",
              "style": "Info"
            }
          },
          {
            "name": "useSameForAll",
            "type": "Microsoft.Common.CheckBox",
            "label": "Use the same action group for all severities (simple setup)",
            "defaultValue": false,
            "toolTip": "If checked, the Severity 0 selection below will be reused for Sev 1 and Sev 2, and the other dropdowns will be hidden."
          },
          {
            "name": "actionGroupSev0",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "🔴 Action Group — Severity 0 (Emergency, Alert, Host-down, Heartbeat)",
            "toolTip": "Notified for the most critical alerts. Leave empty to skip.",
            "resourceType": "Microsoft.Insights/actionGroups",
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "all"
              }
            }
          },
          {
            "name": "actionGroupSev1",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "🟠 Action Group — Severity 1 (Critical, VM, DNS, Role changes)",
            "toolTip": "Notified for high-priority alerts. Leave empty to skip.",
            "resourceType": "Microsoft.Insights/actionGroups",
            "visible": "[not(steps('notifications').useSameForAll)]",
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "all"
              }
            }
          },
          {
            "name": "actionGroupSev2",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "🟡 Action Group — Severity 2 (Error, DFW, Maintenance, Guest Reboot)",
            "toolTip": "Notified for moderate-priority alerts. Leave empty to skip.",
            "resourceType": "Microsoft.Insights/actionGroups",
            "visible": "[not(steps('notifications').useSameForAll)]",
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "all"
              }
            }
          },
          {
            "name": "noGroupWarning",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[and(empty(steps('notifications').actionGroupSev0.id), empty(steps('notifications').actionGroupSev1.id), empty(steps('notifications').actionGroupSev2.id))]",
            "options": {
              "icon": "Warning",
              "text": "⚠️ No action groups selected. Alert rules will still be deployed and visible in Azure Monitor, but nobody will be notified when they fire. Select at least one action group above for notifications to be sent.",
              "style": "Warning"
            }
          }
        ]
      },
      {
        "name": "alertSelection",
        "label": "Select Alerts",
        "elements": [
          {
            "name": "presetInfoBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "icon": "Info",
              "text": "Pick a preset to enable a curated set of alerts, or choose Custom to fine-tune individual alerts. If you enabled 'Use the same action group for all severities' in the previous step, all alerts route to that single group.",
              "style": "Info"
            }
          },
          {
            "name": "alertPreset",
            "type": "Microsoft.Common.OptionsGroup",
            "label": "Alert Preset",
            "defaultValue": "Recommended (curated defaults)",
            "toolTip": "Choose a preset, then expand the details panel below to see exactly which alerts will be deployed.",
            "constraints": {
              "allowedValues": [
                { "label": "Recommended (curated defaults)", "value": "Recommended" },
                { "label": "All Enabled (full coverage, noisier)", "value": "All" },
                { "label": "Minimal (Sev 0 + Host-down + Heartbeat only)", "value": "Minimal" },
                { "label": "Custom (pick individual alerts below)", "value": "Custom" }
              ],
              "required": true
            }
          },
          {
            "name": "presetDetailsRecommended",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('alertSelection').alertPreset, 'Recommended')]",
            "options": {
              "icon": "Info",
              "style": "Info",
              "text": "Recommended (12 of 14 alerts) — Sev 0: Emergency, Alert, Host Connection Lost, Host Shutdown, Syslog Ingestion Heartbeat. Sev 1: Critical, VM Disconnected, VM Removed from Inventory, DNS Failures, Role/Permission Changes. Sev 2: Host Maintenance Mode, VM Guest Reboot, DFW Blocked Spike. Excludes (off by default): Sev 2 Error (high volume), and you can still toggle individual alerts using Custom."
            }
          },
          {
            "name": "presetDetailsAll",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('alertSelection').alertPreset, 'All')]",
            "options": {
              "icon": "Warning",
              "style": "Warning",
              "text": "All Enabled (14 of 14 alerts) — Everything in Recommended PLUS Sev 2 Error (err/error events from any AppName). Use only if you have tuned thresholds and exclusions for your environment, or you risk a noisy on-call rotation."
            }
          },
          {
            "name": "presetDetailsMinimal",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('alertSelection').alertPreset, 'Minimal')]",
            "options": {
              "icon": "Info",
              "style": "Info",
              "text": "Minimal (5 of 14 alerts) — Sev 0 only: Emergency, Alert, Host Connection Lost, Host Shutdown, Syslog Ingestion Heartbeat. Use this for production pilots, or to prove out the routing/action-group setup before turning on Sev 1 and Sev 2."
            }
          },
          {
            "name": "presetDetailsCustom",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[equals(steps('alertSelection').alertPreset, 'Custom')]",
            "options": {
              "icon": "Info",
              "style": "Info",
              "text": "Custom — Pick individual alerts below. Defaults shown next to each checkbox match the Recommended preset."
            }
          },
          {
            "name": "severitySection",
            "type": "Microsoft.Common.Section",
            "label": "Part 1 — Severity-Based Alerts",
            "visible": "[equals(steps('alertSelection').alertPreset, 'Custom')]",
            "elements": [
              {
                "name": "deploySev0Emergency",
                "type": "Microsoft.Common.CheckBox",
                "label": "🔴 Sev 0 — Emergency (emerg / emergency) — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deploySev0Alert",
                "type": "Microsoft.Common.CheckBox",
                "label": "🔴 Sev 0 — Alert — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deploySev1Critical",
                "type": "Microsoft.Common.CheckBox",
                "label": "🟠 Sev 1 — Critical (crit / critical) — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deploySev2Error",
                "type": "Microsoft.Common.CheckBox",
                "label": "🟡 Sev 2 — Error (err / error) — default: ❌ (can be noisy)",
                "defaultValue": false
              }
            ]
          },
          {
            "name": "eventSection",
            "type": "Microsoft.Common.Section",
            "label": "Part 2 — Event-Specific Alerts",
            "visible": "[equals(steps('alertSelection').alertPreset, 'Custom')]",
            "elements": [
              {
                "name": "eventInfoBox",
                "type": "Microsoft.Common.InfoBox",
                "options": {
                  "text": "Each event alert is routed to the action group matching its Azure severity tier (configured in the previous step). Threshold-based alerts (DNS, DFW) have configurable values in the next step.",
                  "style": "Info"
                }
              },
              {
                "name": "sev0Header",
                "type": "Microsoft.Common.TextBlock",
                "visible": true,
                "options": {
                  "text": "🔴 Sev 0 — Critical infrastructure (page on-call)"
                }
              },
              {
                "name": "deploySyslogIngestionHeartbeat",
                "type": "Microsoft.Common.CheckBox",
                "label": "Syslog Ingestion Heartbeat (no-data alert — monitors the monitoring) — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployHostConnectionLost",
                "type": "Microsoft.Common.CheckBox",
                "label": "Host Connection Lost — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployHostShutdown",
                "type": "Microsoft.Common.CheckBox",
                "label": "Host Shutdown — default: ✅",
                "defaultValue": true
              },
              {
                "name": "sev1Header",
                "type": "Microsoft.Common.TextBlock",
                "visible": true,
                "options": {
                  "text": "🟠 Sev 1 — High priority (notify team)"
                }
              },
              {
                "name": "deployVmDisconnected",
                "type": "Microsoft.Common.CheckBox",
                "label": "VM Disconnected — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployVmRemovedFromInventory",
                "type": "Microsoft.Common.CheckBox",
                "label": "VM Removed from Inventory — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployDnsFailures",
                "type": "Microsoft.Common.CheckBox",
                "label": "DNS Failures (threshold-based; configurable in next step) — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployRolePermissionChanges",
                "type": "Microsoft.Common.CheckBox",
                "label": "Role / Permission Changes (Security Audit) — default: ✅",
                "defaultValue": true
              },
              {
                "name": "sev2Header",
                "type": "Microsoft.Common.TextBlock",
                "visible": true,
                "options": {
                  "text": "🟡 Sev 2 — Moderate priority (informational)"
                }
              },
              {
                "name": "deployVmGuestReboot",
                "type": "Microsoft.Common.CheckBox",
                "label": "VM Guest Reboot — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployDfwSpike",
                "type": "Microsoft.Common.CheckBox",
                "label": "Distributed Firewall Blocked Spike (threshold-based; configurable in next step) — default: ✅",
                "defaultValue": true
              },
              {
                "name": "deployHostMaintenanceMode",
                "type": "Microsoft.Common.CheckBox",
                "label": "Host Maintenance Mode — default: ✅",
                "defaultValue": true
              }
            ]
          }
        ]
      },
      {
        "name": "thresholds",
        "label": "Thresholds",
        "elements": [
          {
            "name": "infoBox",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "text": "These three alerts are volume-based — individual events are normal, but a spike indicates a problem. All other alerts in this solution fire on first occurrence (severity-based or discrete events like host shutdowns) and don't need a threshold. Thresholds apply per host per 15-minute evaluation window. See the README threshold-tuning guide for help adjusting these values.",
              "style": "Info"
            }
          },
          {
            "name": "errThresholdPer15m",
            "type": "Microsoft.Common.Slider",
            "label": "Error events threshold (per 15 min)",
            "subLabel": "events",
            "defaultValue": 5,
            "min": 1,
            "max": 100,
            "showStepMarkers": false,
            "toolTip": "Number of err/error events per HostName + AppName in 15 minutes before alerting. Recommended baseline: 5 (default). Raise to 10–20 if you see frequent transient errors from a single AppName. Lower to 2–3 only for very stable environments."
          },
          {
            "name": "dnsFailureThresholdPer15m",
            "type": "Microsoft.Common.Slider",
            "label": "DNS failure threshold (per 15 min)",
            "subLabel": "failures",
            "defaultValue": 10,
            "min": 1,
            "max": 200,
            "showStepMarkers": false,
            "toolTip": "Number of DNS failures per host in 15 minutes before alerting. Recommended baseline: 10 (default). Raise to 25–50 if your VMs frequently query non-existent records (e.g., scanning, misconfigured apps). Lower to 5 if you want early warning of DNS server issues."
          },
          {
            "name": "dfwSpikeThresholdPer15m",
            "type": "Microsoft.Common.Slider",
            "label": "DFW blocked spike threshold (per 15 min)",
            "subLabel": "blocks",
            "defaultValue": 50,
            "min": 1,
            "max": 500,
            "showStepMarkers": false,
            "toolTip": "Number of blocked firewall events per host in 15 minutes before alerting. Recommended baseline: 50 (default). Raise to 100–200 for high-traffic clusters or environments with deny-by-default policies. Lower to 20 for security-sensitive workloads where any spike matters."
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "workspaceResourceId": "[basics('workspaceSelector').id]",
      "alertNamePrefix": "[basics('alertNamePrefix')]",
      "actionGroupIdSev0": "[if(empty(steps('notifications').actionGroupSev0.id), '', steps('notifications').actionGroupSev0.id)]",
      "actionGroupIdSev1": "[if(steps('notifications').useSameForAll, if(empty(steps('notifications').actionGroupSev0.id), '', steps('notifications').actionGroupSev0.id), if(empty(steps('notifications').actionGroupSev1.id), '', steps('notifications').actionGroupSev1.id))]",
      "actionGroupIdSev2": "[if(steps('notifications').useSameForAll, if(empty(steps('notifications').actionGroupSev0.id), '', steps('notifications').actionGroupSev0.id), if(empty(steps('notifications').actionGroupSev2.id), '', steps('notifications').actionGroupSev2.id))]",
      "errThresholdPer15m": "[steps('thresholds').errThresholdPer15m]",
      "dnsFailureThresholdPer15m": "[steps('thresholds').dnsFailureThresholdPer15m]",
      "dfwSpikeThresholdPer15m": "[steps('thresholds').dfwSpikeThresholdPer15m]",
      "deploySev0Emergency": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), true, steps('alertSelection').severitySection.deploySev0Emergency)))]",
      "deploySev0Alert": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), true, steps('alertSelection').severitySection.deploySev0Alert)))]",
      "deploySev1Critical": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').severitySection.deploySev1Critical)))]",
      "deploySev2Error": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), false, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').severitySection.deploySev2Error)))]",
      "deployHostConnectionLost": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), true, steps('alertSelection').eventSection.deployHostConnectionLost)))]",
      "deployHostShutdown": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), true, steps('alertSelection').eventSection.deployHostShutdown)))]",
      "deployVmDisconnected": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployVmDisconnected)))]",
      "deployVmRemovedFromInventory": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployVmRemovedFromInventory)))]",
      "deployVmGuestReboot": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployVmGuestReboot)))]",
      "deployDnsFailures": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployDnsFailures)))]",
      "deployDfwSpike": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployDfwSpike)))]",
      "deployHostMaintenanceMode": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployHostMaintenanceMode)))]",
      "deployRolePermissionChanges": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), false, steps('alertSelection').eventSection.deployRolePermissionChanges)))]",
      "deploySyslogIngestionHeartbeat": "[if(equals(steps('alertSelection').alertPreset, 'All'), true, if(equals(steps('alertSelection').alertPreset, 'Recommended'), true, if(equals(steps('alertSelection').alertPreset, 'Minimal'), true, steps('alertSelection').eventSection.deploySyslogIngestionHeartbeat)))]"
    }
  }
}
